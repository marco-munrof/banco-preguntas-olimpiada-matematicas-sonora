  <question type="stack">
    <name>
      <text>P01 - Dígitos en potencias de 2 y 5</text>
    </name>
    <questiontext format="html">
      <text><![CDATA[<p>¿Cuántas cifras tiene el resultado del siguiente número al desarrollarlo por completo?</p>
<p>\( 2^{{@x@}} \times 5^{{@y@}} \)</p>
<p>[[input:ans1]] [[validation:ans1]]</p>]]></text>
    </questiontext>
    <generalfeedback format="html">
      <text></text>
    </generalfeedback>
    <defaultgrade>1.0000000</defaultgrade>
    <penalty>0.0000000</penalty>
    <hidden>0</hidden>
    <idnumber></idnumber>
    <stackversion>
      <text>2025040100</text>
    </stackversion>
    <questionvariables>
      <text><![CDATA[/* Generamos exponentes grandes y aleatorios */
x: 2 + rand(9);
y: 2 + rand(7);

/* Encuentramos el mínimo para formar los pares de 10 */
minXY: min(x, y);

/* Determinamos qué base sobra y cuál es la diferencia de exponentes */
diff: abs(x - y);
if x > y then base_sobrante: 2 else base_sobrante: 5;

/* Calculamos el valor sobrante y contamos sus dígitos convirtiéndolo a texto */
valor_sobrante: base_sobrante^diff;
digitos_extra: slength(string(valor_sobrante));

/* La respuesta total es los ceros (minXY) más los dígitos del número sobrante */
ta1: minXY + digitos_extra;]]></text>
