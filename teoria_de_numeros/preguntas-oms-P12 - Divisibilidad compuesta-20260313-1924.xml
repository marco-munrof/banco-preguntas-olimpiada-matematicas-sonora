  <question type="stack">
    <name>
      <text>P12 - Divisibilidad compuesta</text>
    </name>
    <questiontext format="moodle_auto_format">
      <text><![CDATA[Responde "Verdadero" o "Falso" a la siguiente afirmacion.

Si un numero natural es divisible por {@A@} y por {@B@}, entonces forzosamente es divisible por {@producto@}.

[[input:ans1]] [[validation:ans1]]]]></text>
    </questiontext>
    <generalfeedback format="html">
      <text></text>
    </generalfeedback>
    <defaultgrade>1</defaultgrade>
    <penalty>0</penalty>
    <hidden>0</hidden>
    <idnumber></idnumber>
    <stackversion>
      <text>2025040100</text>
    </stackversion>
    <questionvariables>
      <text><![CDATA[/* Elegimos al azar si la afirmacion sera verdadera o falsa */
tipo_caso: rand(2);

if tipo_caso = 1 then (
A: 2 + rand(3),
B: 5 + rand(4),
if gcd(A, B) > 1 then B: B + 1,
producto: A * B,
mcd_val: 1,
ta1: "Verdadero",
retro: sconcat("Como ", A, " y ", B, " son primos relativos (su MCD es 1), un numero divisible por ambos forzosamente es divisible por su producto.")
) else (
factor_comun: 2 + rand(3),
A: factor_comun * (1 + rand(2)),
B: factor_comun * (2 + rand(2)),
if A = B then B: B + factor_comun,
producto: A * B,
mcd_val: gcd(A, B),
ta1: "Falso",
retro: sconcat(A," y ", B, " comparten factores. El maximo comun divisor de ", A, " y ", B, " es ", mcd_val, ". Un numero divisible por ambos no necesariamente es divisible por su producto.")
);]]></text>
    </questionvariables>
    <specificfeedback format="html">
